# Sanity CMS Configuration
# ─────────────────────────────────────────────────────────
# 1. Create a free project at https://sanity.io
# 2. Run: npx sanity init (or set up via dashboard)
# 3. Copy this file to .env.local and fill in the values
# ─────────────────────────────────────────────────────────

NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: write token for mutations from the app (keep secret, never expose to browser)
# SANITY_API_WRITE_TOKEN=your_write_token_here
