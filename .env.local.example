# ─── Payload CMS ─────────────────────────────────────────────────────────────
# Required: at least 32 random characters, used for JWT signing
PAYLOAD_SECRET=your-super-secret-key-change-this-in-production

# SQLite database path (relative to project root)
DATABASE_URI=file:./data/payload.db

# Public URL of the site (used by Payload for image URLs, etc.)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Site Configuration ──────────────────────────────────────────────────────
# IANA timezone for date display and "upcoming" event logic (default: America/Chicago)
SITE_TIMEZONE=America/Chicago

# ─── Preview (Draft Mode) ───────────────────────────────────────────────────
PREVIEW_SECRET=your-preview-secret

# ─── Social Login (Future — via payload-oauth2) ─────────────────────────────
# Google (https://console.cloud.google.com → APIs & Services → Credentials)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
