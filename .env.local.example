# ─── Payload CMS ─────────────────────────────────────────────────────────────
# Required: at least 14 random characters, used for JWT signing
PAYLOAD_SECRET=your-super-secret-key-change-this-in-production

# SQLite database path (relative to project root)
DATABASE_URI=file:./data/payload.db

# Public URL of the site (used by Payload for image URLs, etc.)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Required: at least 32 random characters (different from PAYLOAD_SECRET)
BETTER_AUTH_SECRET=another-long-random-secret-for-sessions

# Public URL used by the auth client
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Social Login Providers ───────────────────────────────────────────────────
# Google (https://console.cloud.google.com → APIs & Services → Credentials)
# Callback: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub (https://github.com/settings/developers → OAuth Apps)
# Callback: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Apple — requires paid Apple Developer account ($99/year)
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# Facebook/Meta — requires Facebook App review
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# Twitter/X — requires Twitter Developer account
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=

# ─── Contact Form Email (AWS SES SMTP) ──────────────────────────────────────
# SMTP credentials from AWS SES console (SES > SMTP Settings > Create SMTP credentials)
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Where contact form emails are sent TO and FROM
CONTACT_EMAIL_TO=sprechereast@gmail.com
CONTACT_EMAIL_FROM=sprechereast@gmail.com
